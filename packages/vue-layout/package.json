{
  "name": "@prefabs.tech/vue3-layout",
  "version": "0.32.0",
  "description": "Vue3 Layout Plugin",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/PrefabsTechVue3Layout.es.js",
      "require": "./dist/PrefabsTechVue3Layout.umd.js"
    },
    "./dist/PrefabsTechVue3Layout.css": "./dist/vue3-layout.css"
  },
  "main": "dist//PrefabsTechVue3Layout.umd.js",
  "module": "dist//PrefabsTechVue3Layout.es.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "snapshot:update": "vitest --environment jsdom run --update --passWithNoTests",
    "sort-package": "npx sort-package-json",
    "stylelint": "stylelint \"src/**/*.{css,vue}\" --allow-empty-input",
    "stylelint:fix": "stylelint \"src/**/*.{css,vue}\" --fix --allow-empty-input",
    "test": "vitest --environment jsdom run --coverage --passWithNoTests",
    "test:component": "vitest --environment jsdom run component/ --passWithNoTests",
    "test:snapshot": "vitest --environment jsdom run snapshot/ --passWithNoTests",
    "test:unit": "vitest --environment jsdom run unit/ --passWithNoTests",
    "test:watch": "vitest --environment jsdom",
    "typecheck": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false"
  },
  "devDependencies": {
    "@prefabs.tech/eslint-config": "0.8.7",
    "@prefabs.tech/stylelint-config": "0.8.7",
    "@prefabs.tech/tsconfig": "0.8.7",
    "@prefabs.tech/vue3-config": "0.32.0",
    "@prefabs.tech/vue3-i18n": "0.32.0",
    "@prefabs.tech/vue3-ui": "0.32.0",
    "@iconify/vue": "4.3.0",
    "@types/node": "25.6.0",
    "@vitejs/plugin-vue": "6.0.6",
    "@vitejs/plugin-vue-jsx": "5.1.5",
    "@vitest/coverage-istanbul": "4.1.5",
    "@vue/test-utils": "2.4.10",
    "@vueuse/core": "14.3.0",
    "eslint": "10.6.0",
    "prettier": "3.8.3",
    "stylelint": "17.10.0",
    "stylelint-config-recommended-vue": "1.6.1",
    "stylelint-order": "8.1.1",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vitest": "4.1.5",
    "vue": "3.5.33",
    "vue-router": "5.0.6",
    "vue-tsc": "2.2.12"
  },
  "peerDependencies": {
    "@prefabs.tech/vue3-config": "0.32.0",
    "@prefabs.tech/vue3-i18n": "0.32.0",
    "@prefabs.tech/vue3-ui": "0.32.0",
    "@vueuse/core": ">=9.13.0",
    "vue": ">=3.5",
    "vue-router": ">=4.6"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  }
}
