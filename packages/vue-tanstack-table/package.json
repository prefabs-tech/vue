{
  "name": "@prefabs.tech/vue3-tanstack-table",
  "version": "0.32.0",
  "description": "Vue3 Tanstack Table Component Library",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/PrefabsTechVue3TanstackTable.es.js",
      "require": "./dist/PrefabsTechVue3TanstackTable.umd.js"
    },
    "./dist/PrefabsTechVue3TanstackTable.css": "./dist/vue3-tanstack-table.css"
  },
  "main": "./dist/PrefabsTechVue3TanstackTable.umd.js",
  "module": "./dist/PrefabsTechVue3TanstackTable.es.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "snapshot:update": "vitest --environment jsdom run --update --passWithNoTests",
    "sort-package": "npx sort-package-json",
    "stylelint": "stylelint \"src/**/*.{css,vue}\" --allow-empty-input",
    "stylelint:fix": "stylelint \"src/**/*.{css,vue}\" --fix --allow-empty-input",
    "test": "vitest --environment jsdom run --coverage --passWithNoTests",
    "test:component": "vitest --environment jsdom run component/ --passWithNoTests",
    "test:snapshot": "vitest --environment jsdom run snapshot/ --passWithNoTests",
    "test:unit": "vitest --environment jsdom run unit/ --passWithNoTests",
    "test:watch": "vitest --environment jsdom",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json --composite false"
  },
  "dependencies": {
    "@tanstack/vue-table": "8.21.3"
  },
  "devDependencies": {
    "@prefabs.tech/eslint-config": "git+https://github.com/prefabs-tech/tools.git#refactor/eslint-config&path:packages/eslint-config",
    "@prefabs.tech/stylelint-config": "git+https://github.com/prefabs-tech/tools.git#refactor/eslint-config&path:packages/stylelint-config",
    "@prefabs.tech/tsconfig": "0.6.0",
    "@prefabs.tech/vue3-form": "0.32.0",
    "@prefabs.tech/vue3-ui": "0.32.0",
    "@iconify/vue": "4.3.0",
    "@types/node": "25.3.5",
    "@vitejs/plugin-vue": "6.0.6",
    "@vitejs/plugin-vue-jsx": "5.1.5",
    "@vitest/coverage-istanbul": "4.0.18",
    "@vue/test-utils": "2.4.6",
    "@vueuse/core": "14.2.1",
    "eslint": "9.39.4",
    "prettier": "3.8.3",
    "stylelint": "17.9.1",
    "stylelint-config-recommended-vue": "1.6.1",
    "stylelint-order": "8.1.1",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vitest": "4.0.18",
    "vue": "3.5.33",
    "vue-tsc": "3.2.7"
  },
  "peerDependencies": {
    "@prefabs.tech/vue3-form": "0.32.0",
    "@prefabs.tech/vue3-ui": "0.32.0",
    "vue": ">=3.2"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  }
}
