{
  "name": "@prefabs.tech/vue3-form",
  "version": "0.32.0",
  "description": "Vue Form plugin",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/PrefabsTechVue3Form.es.js",
      "require": "./dist/PrefabsTechVue3Form.umd.js"
    },
    "./dist/PrefabsTechFlagIcon.css": "./dist/flag-icon.css",
    "./dist/PrefabsTechVue3Form.css": "./dist/vue3-form.css"
  },
  "main": "./dist/PrefabsTechVue3Form.umd.js",
  "module": "./dist/PrefabsTechVue3Form.es.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "snapshot:update": "vitest --environment jsdom run --update --passWithNoTests",
    "sort-package": "npx sort-package-json",
    "stylelint": "stylelint \"src/**/*.{css,vue}\" --allow-empty-input",
    "stylelint:fix": "stylelint \"src/**/*.{css,vue}\" --fix --allow-empty-input",
    "test": "vitest --environment jsdom run --coverage --passWithNoTests",
    "test:component": "vitest --environment jsdom run component/ --passWithNoTests",
    "test:snapshot": "vitest --environment jsdom run snapshot/ --passWithNoTests",
    "test:unit": "vitest --environment jsdom run unit/ --passWithNoTests",
    "test:watch": "vitest --environment jsdom",
    "typecheck": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false"
  },
  "dependencies": {
    "validator": "13.15.35"
  },
  "devDependencies": {
    "@dzangolab/flag-icon-css": "3.4.5",
    "@prefabs.tech/eslint-config": "0.8.7",
    "@prefabs.tech/stylelint-config": "0.8.7",
    "@prefabs.tech/tsconfig": "0.8.7",
    "@prefabs.tech/vue3-ui": "0.32.0",
    "@types/node": "26.1.1",
    "@types/validator": "13.15.10",
    "@vee-validate/i18n": "4.15.1",
    "@vee-validate/rules": "4.15.1",
    "@vee-validate/zod": "4.15.1",
    "@vitejs/plugin-vue": "6.0.8",
    "@vitejs/plugin-vue-jsx": "5.1.6",
    "@vitest/coverage-istanbul": "4.1.10",
    "@vue/test-utils": "2.4.11",
    "@vuepic/vue-datepicker": "12.1.0",
    "@vueuse/core": "14.3.0",
    "eslint": "10.7.0",
    "prettier": "3.9.5",
    "stylelint": "17.14.1",
    "stylelint-config-recommended-vue": "1.6.1",
    "stylelint-order": "8.1.1",
    "typescript": "6.0.3",
    "vee-validate": "4.15.1",
    "vite": "8.1.5",
    "vitest": "4.1.10",
    "vue": "3.5.40",
    "vue-tsc": "3.3.7",
    "vue3-dropzone": "2.2.1",
    "zod": "3.25.76"
  },
  "peerDependencies": {
    "@vee-validate/i18n": ">=4.15.1",
    "@vee-validate/rules": ">=4.15.1",
    "@vee-validate/zod": ">=4.15.1",
    "vee-validate": ">=4.15.1",
    "vue": ">=3.5",
    "zod": ">=3.25.76"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  }
}
