{
  "name": "@prefabs.tech/vue3-config",
  "version": "0.32.0",
  "description": "Vue config plugin",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/PrefabsTechVue3Config.es.js",
      "require": "./dist/PrefabsTechVue3Config.umd.js"
    }
  },
  "main": "./dist/PrefabsTechVue3Config.umd.js",
  "module": "./dist/PrefabsTechVue3Config.es.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "snapshot:update": "vitest --environment jsdom run --update --passWithNoTests",
    "sort-package": "npx sort-package-json",
    "stylelint": "stylelint \"src/**/*.{css,vue}\" --allow-empty-input",
    "stylelint:fix": "stylelint \"src/**/*.{css,vue}\" --fix --allow-empty-input",
    "test": "vitest --environment jsdom run --coverage --passWithNoTests",
    "test:component": "vitest --environment jsdom run component/ --passWithNoTests",
    "test:snapshot": "vitest --environment jsdom run snapshot/ --passWithNoTests",
    "test:unit": "vitest --environment jsdom run unit/ --passWithNoTests",
    "test:watch": "vitest --environment jsdom",
    "typecheck": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false"
  },
  "dependencies": {
    "@sentry/core": "10.66.0",
    "@sentry/vue": "10.66.0"
  },
  "devDependencies": {
    "@prefabs.tech/eslint-config": "0.8.7",
    "@prefabs.tech/stylelint-config": "0.8.7",
    "@prefabs.tech/tsconfig": "0.8.7",
    "@types/node": "26.1.1",
    "@vitejs/plugin-vue": "6.0.8",
    "@vitejs/plugin-vue-jsx": "5.1.6",
    "@vitest/coverage-istanbul": "4.1.10",
    "eslint": "10.7.0",
    "prettier": "3.9.5",
    "stylelint": "17.14.1",
    "stylelint-config-recommended-vue": "1.6.1",
    "stylelint-order": "8.1.1",
    "typescript": "6.0.3",
    "vite": "8.1.5",
    "vitest": "4.1.10",
    "vue": "3.5.40",
    "vue-router": "5.2.0",
    "vue-tsc": "3.3.7"
  },
  "peerDependencies": {
    "vue": ">=3.5",
    "vue-router": ">=5.2"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  }
}
