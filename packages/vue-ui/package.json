{
  "name": "@prefabs.tech/vue3-ui",
  "version": "0.32.0",
  "description": "Vue3 UI Component Library",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/PrefabsTechVue3UI.es.js",
      "require": "./dist/PrefabsTechVue3UI.umd.js"
    },
    "./dist/PrefabsTechVue3UI.css": "./dist/vue3-ui.css"
  },
  "main": "./dist/PrefabsTechVue3UI.umd.js",
  "module": "./dist/PrefabsTechVue3UI.es.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "snapshot:update": "vitest --environment jsdom run --update",
    "sort-package": "npx sort-package-json",
    "test": "vitest --environment jsdom run --coverage --passWithNoTests",
    "test:component": "vitest --environment jsdom run component/ --passWithNoTests",
    "test:snapshot": "vitest --environment jsdom run snapshot/ --passWithNoTests",
    "test:unit": "vitest --environment jsdom run unit/ --passWithNoTests",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json --composite false"
  },
  "devDependencies": {
    "@prefabs.tech/eslint-config": "0.5.0",
    "@prefabs.tech/tsconfig": "0.5.0",
    "@types/node": "25.3.1",
    "@vitejs/plugin-vue": "6.0.5",
    "@vitejs/plugin-vue-jsx": "5.1.5",
    "@vitest/coverage-istanbul": "4.1.3",
    "@vue/test-utils": "2.4.6",
    "@vueuse/core": "14.2.1",
    "eslint": "9.39.2",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vitest": "4.1.3",
    "vue": "3.5.27",
    "vue-draggable-next": "2.3.0",
    "vue-tsc": "3.2.4"
  },
  "peerDependencies": {
    "vue": ">=3.2"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  }
}
