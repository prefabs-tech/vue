{
  "name": "@prefabs.tech/vue3-i18n",
  "version": "0.32.0",
  "description": "Vue3 I18n Plugin",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/PrefabsTechVue3I18n.es.js",
      "require": "./dist/PrefabsTechVue3I18n.umd.js"
    },
    "./dist/PrefabsTechVue3I18n.css": "./dist/vue3-i18n.css"
  },
  "main": "./dist/PrefabsTechVue3I18n.umd.js",
  "module": "./dist/PrefabsTechVue3I18n.es.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "snapshot:update": "vitest --environment jsdom run --update",
    "sort-package": "npx sort-package-json",
    "stylelint": "stylelint \"src/**/*.{css,vue}\" --allow-empty-input",
    "stylelint:fix": "stylelint \"src/**/*.{css,vue}\" --fix --allow-empty-input",
    "test": "vitest --environment jsdom run --coverage --passWithNoTests",
    "test:component": "vitest --environment jsdom run component/ --passWithNoTests",
    "test:snapshot": "vitest --environment jsdom run snapshot/ --passWithNoTests",
    "test:unit": "vitest --environment jsdom run unit/ --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false"
  },
  "dependencies": {
    "vue-i18n": "11.4.7"
  },
  "devDependencies": {
    "@prefabs.tech/eslint-config": "0.8.7",
    "@prefabs.tech/stylelint-config": "0.8.7",
    "@prefabs.tech/tsconfig": "0.8.7",
    "@prefabs.tech/vue3-config": "0.32.0",
    "@types/node": "26.1.1",
    "@vitejs/plugin-vue": "6.0.8",
    "@vitejs/plugin-vue-jsx": "5.1.6",
    "@vitest/coverage-istanbul": "4.1.10",
    "@vue/test-utils": "2.4.11",
    "@vueuse/core": "14.3.0",
    "eslint": "10.7.0",
    "jsdom": "29.1.1",
    "pinia": "4.0.2",
    "prettier": "3.9.5",
    "stylelint": "17.14.1",
    "stylelint-config-recommended-vue": "1.6.1",
    "stylelint-order": "8.1.1",
    "typescript": "6.0.3",
    "vite": "8.1.5",
    "vitest": "4.1.10",
    "vue": "3.5.40",
    "vue-tsc": "3.3.7"
  },
  "peerDependencies": {
    "@prefabs.tech/vue3-config": "0.32.0",
    "@vueuse/core": ">=14.3.0",
    "pinia": ">=4.0",
    "vue": ">=3.5"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  }
}
